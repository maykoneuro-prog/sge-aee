rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      // Note: get() inside rules is used for RBAC checks
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && (
        data.role == 'admin' || 
        data.role == 'super-admin' ||
        request.auth.token.email == 'maykon.euro@gmail.com' ||
        request.auth.token.email == 'administrador@exemplo.com'
      );
    }
    
    function isOwner(data) {
      return isSignedIn() && (data.ownerId == request.auth.uid || data.ownerId == request.auth.token.email);
    }

    // Rules for Schools
    match /schools/{schoolId} {
      allow list: if isSignedIn(); // Listed schools are filtered by frontend, but rules allow reading if authenticated
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }
    
    // Rules for Students
    match /students/{studentId} {
      allow read, write: if isSignedIn();
    }

    // Rules for Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Rules for Appointments
    match /appointments/{appointmentId} {
      allow read, write: if isSignedIn();
    }

    // Rules for Anonymous Reports
    match /anonymous_reports/{reportId} {
      allow create: if true; // Public can create
      allow read: if isSignedIn() && isAdmin(); // Only admins can read
      allow update, delete: if isSignedIn() && isAdmin();
    }

    // Test collection for connection diagnostics
    match /test/{docId} {
      allow read: if true;
    }

    // Fallback for other identified collections
    match /scheduling_requests/{id} { allow read, write: if isSignedIn(); }
    match /documents/{id} { allow read, write: if isSignedIn(); }
    match /plans/{id} { allow read: if true; allow write: if isAdmin(); }
    match /subscriptions/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}
