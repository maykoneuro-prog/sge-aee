rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Basic Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    // Identity Helpers
    function isUser(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Role Helpers
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '2JlwnRjqFrYtKCfaajsAoNRDqnt1' ||
        request.auth.token.email == 'maykon.euro@gmail.com' ||
        request.auth.token.email == 'administrador@sgepsicologia.com' ||
        request.auth.token.email == 'administrador@exemplo.com' ||
        request.auth.uid == 'super_admin'
      );
    }
    
    function isOwner(resourceData) {
      return isSignedIn() && (
        resourceData.ownerId == request.auth.uid || 
        resourceData.ownerId == request.auth.token.email ||
        resourceData.get('email', '') == request.auth.token.email
      );
    }

    function isUnitMember(resourceData) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         resourceData.get('unit', '') in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('units', []))
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collections ---

    // Rules for Users
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Rules for Schools
    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }
    
    // Rules for Categories and Appointment Types
    match /categories/{id} { allow read: if true; allow write: if isAdmin(); }
    match /appointment_types/{id} { allow read: if true; allow write: if isAdmin(); }

    // Rules for Scheduling Requests
    match /scheduling_requests/{id} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }
    
    // Rules for Anonymous Reports
    match /anonymous_reports/{reportId} {
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    // Rules for Students
    match /students/{studentId} {
      allow read, write: if isSignedIn();
    }

    // Rules for Appointments
    match /appointments/{appointmentId} {
      allow read, write: if isSignedIn();
    }

    // Rules for Logs and Tracking
    match /usage_logs/{id} { allow read, write: if isSignedIn(); }
    match /leads/{id} { allow create: if true; allow read, write: if isAdmin(); }
    
    // Rules for Content and Settings
    match /plans/{id} { allow read: if true; allow write: if isAdmin(); }
    match /app_settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /documents/{id} { allow read, write: if isSignedIn(); }
    match /document_layouts/{id} { allow read, write: if isSignedIn(); }
    match /subscriptions/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /letterheads/{id} { allow read: if true; allow write: if isSignedIn(); }

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
